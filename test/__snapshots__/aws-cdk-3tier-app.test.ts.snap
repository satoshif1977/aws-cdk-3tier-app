          "SecretStringTemplate": "{"username":"admin"}",
        },
        "Name": "cdk-3tier-db-secret",
        "Tags": [
          {
            "Key": "ManagedBy",
            "Value": "CDK",
          },
          {
            "Key": "Project",
            "Value": "cdk-3tier-app",
          },
        ],
      },
      "Type": "AWS::SecretsManager::Secret",
      "UpdateReplacePolicy": "Delete",
    },
    "WebServerInstance244889AB": {
      "DependsOn": [
        "WebServerRoleFA0E13F4",
      ],
      "Properties": {
        "AvailabilityZone": "dummy1a",
        "IamInstanceProfile": {
          "Ref": "WebServerInstanceInstanceProfile32EAD166",
