          },
          {
            "Key": "Name",
            "Value": "cdk-3tier-web",
          },
          {
            "Key": "Project",
            "Value": "cdk-3tier-app",
          },
        ],
        "UserData": {
          "Fn::Base64": "#!/bin/bash
dnf update -y
dnf install -y httpd
systemctl enable httpd
systemctl start httpd
echo "<h1>Hello from CDK 3-Tier App</h1>" > /var/www/html/index.html",
        },
      },
      "Type": "AWS::EC2::Instance",
    },
